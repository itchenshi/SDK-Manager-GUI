<UserControl x:Class="SDK_Manager_GUI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignHeight="600" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{DynamicResource Dashboard_Title}" FontSize="24" FontWeight="Bold" Foreground="#1A1A2E"/>
            <Button Grid.Column="1" Content="{DynamicResource Common_Refresh}" Command="{Binding RefreshCommand}" Padding="12,6"
                    Background="#F0F0F5" BorderThickness="0" Cursor="Hand"/>
        </Grid>

        <!-- 加载中提示 -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding IsRefreshing, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="{DynamicResource Dashboard_Detecting}" FontSize="14" Foreground="#999999"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- 空状态提示 -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,40,0,0">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsRefreshing}" Value="False"/>
                                <Condition Binding="{Binding SdkStatusItems.Count}" Value="0"/>
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Visible"/>
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <TextBlock Text="{DynamicResource Dashboard_NoStatus}" FontSize="14" Foreground="#999999" HorizontalAlignment="Center"/>
            <TextBlock Text="{DynamicResource Dashboard_CheckNetwork}" FontSize="12" Foreground="#BBBBBB" HorizontalAlignment="Center" Margin="0,4,0,0"/>
        </StackPanel>

        <ItemsControl Grid.Row="1" ItemsSource="{Binding SdkStatusItems}">
            <ItemsControl.Style>
                <Style TargetType="ItemsControl">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsRefreshing}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ItemsControl.Style>
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="1"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Margin="6" Background="#FFFFFF" CornerRadius="10" Padding="16"
                            BorderBrush="#E8E8E8" BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.08"/>
                        </Border.Effect>
                        <StackPanel VerticalAlignment="Stretch">
                            <!-- 语言名称 + 状态标签 -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Language}" FontSize="22" FontWeight="Bold"
                                           Foreground="#1A1A2E"/>
                                <Border Grid.Column="1" CornerRadius="10" Padding="10,3" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#E8F5E9"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsInstalled}" Value="False">
                                                    <Setter Property="Background" Value="#FFF3E0"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="11" FontWeight="Medium">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{DynamicResource Common_Managed}"/>
                                                <Setter Property="Foreground" Value="#4CAF50"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsInstalled}" Value="False">
                                                        <Setter Property="Text" Value="{DynamicResource Common_NotInstalled}"/>
                                                        <Setter Property="Foreground" Value="#FF9800"/>
                                                    </DataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsInstalled}" Value="True"/>
                                                            <Condition Binding="{Binding IsManaged}" Value="False"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Text" Value="{DynamicResource Common_SystemLevel}"/>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </Grid>

                            <!-- 分隔线 -->
                            <Border Height="1" Background="#F0F0F0" Margin="0,0,0,12"/>

                            <!-- 用户级信息 -->
                            <Border Background="#F1F8E9" CornerRadius="6" Padding="10,8" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource Common_UserLevel}" FontSize="11" Foreground="#2E7D32"
                                               FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" FontSize="12" Foreground="#333333"
                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                                               FontWeight="Medium">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding UserLevelVersion, Mode=OneWay}"/>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,4,0,0">
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding UserLevelPath}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding UserLevelPath}" FontSize="10" Foreground="#888888"
                                                   TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                                                   ToolTip="{Binding UserLevelPath}"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="4,0,0,0">
                                            <Button Content="{DynamicResource Common_Copy}" Padding="3,1" FontSize="9" Margin="1,0"
                                                    Background="#F5F5F5" Foreground="#888888" BorderThickness="0" Cursor="Hand"
                                                    Command="{Binding DataContext.CopyPathCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding UserLevelPath}"/>
                                            <Button Content="{DynamicResource Common_Open}" Padding="3,1" FontSize="9" Margin="1,0"
                                                    Background="#F5F5F5" Foreground="#888888" BorderThickness="0" Cursor="Hand"
                                                    Command="{Binding DataContext.OpenPathCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding UserLevelPath}"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- 系统级信息 -->
                            <Border Background="#E3F2FD" CornerRadius="6" Padding="10,8" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource Common_SystemLevel}" FontSize="11" Foreground="#1565C0"
                                               FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" FontSize="12" Foreground="#333333"
                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                                               FontWeight="Medium">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding SystemLevelVersion, Mode=OneWay}"/>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,4,0,0">
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SystemLevelPath}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding SystemLevelPath}" FontSize="10" Foreground="#888888"
                                                   TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                                                   ToolTip="{Binding SystemLevelPath}"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="4,0,0,0">
                                            <Button Content="{DynamicResource Common_Copy}" Padding="3,1" FontSize="9" Margin="1,0"
                                                    Background="#F5F5F5" Foreground="#888888" BorderThickness="0" Cursor="Hand"
                                                    Command="{Binding DataContext.CopyPathCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding SystemLevelPath}"/>
                                            <Button Content="{DynamicResource Common_Open}" Padding="3,1" FontSize="9" Margin="1,0"
                                                    Background="#F5F5F5" Foreground="#888888" BorderThickness="0" Cursor="Hand"
                                                    Command="{Binding DataContext.OpenPathCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding SystemLevelPath}"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- 镜像源信息 -->
                            <Border Background="#FFF8E1" CornerRadius="6" Padding="10,6" Margin="0,0,0,12">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Language}" Value="Maven">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{DynamicResource Dashboard_MirrorSource}" FontSize="11" Foreground="#E65100"
                                               FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="1" Text="{Binding PackageManagerMirror}" FontSize="11" Foreground="#5D4037"
                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                                               ToolTip="{Binding PackageManagerMirror}"/>
                                </Grid>
                            </Border>

                            <!-- Maven 镜像源信息（仅 Maven 卡片显示） -->
                            <Border Background="#FFF8E1" CornerRadius="6" Padding="10,6" Margin="0,0,0,12">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Language}" Value="Maven">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{DynamicResource Dashboard_DepMirrorSource}" FontSize="11" Foreground="#E65100"
                                               FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="1" Text="{Binding MavenMirrorUrl}" FontSize="11" Foreground="#5D4037"
                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                                               ToolTip="{Binding MavenMirrorUrl}"/>
                                </Grid>
                            </Border>

                            <!-- 管理按钮 -->
                            <Button Content="{DynamicResource Dashboard_Manage}" Padding="0,6" HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    FontSize="13" FontWeight="Medium"
                                    Background="#F5F5FA" Foreground="#0066CC" BorderThickness="0" Cursor="Hand"
                                    Command="{Binding DataContext.NavigateToSdkDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding Language}"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
