<UserControl x:Class="SDK_Manager_GUI.Views.LogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignHeight="600" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Text="{DynamicResource Log_Title}" FontSize="24" FontWeight="Bold" Foreground="#1A1A2E" Margin="0,0,0,12"/>

        <!-- 工具栏 -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Margin="0,0,8,0" VerticalAlignment="Center">
                <TextBlock Text="{DynamicResource Common_Date}" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox ItemsSource="{Binding AvailableDates}" SelectedItem="{Binding SelectedDate}"
                          Width="150" Padding="6,4">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding StringFormat='{}{0:yyyy-MM-dd}'}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
            <TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Padding="6,4" ToolTip="{DynamicResource Log_SearchContent}"/>
            <ComboBox Grid.Column="2" Margin="8,0,0,0"
                      ItemsSource="{Binding LevelOptions}"
                      SelectedItem="{Binding FilterLevel}" Padding="6,4"/>
            <TextBlock Grid.Column="3" Text="{Binding LogInfo}" FontSize="12" Foreground="#999999"
                       VerticalAlignment="Center" Margin="12,0,0,0" TextTrimming="CharacterEllipsis"/>
            <StackPanel Grid.Column="4" Orientation="Horizontal">
                <Button Content="{DynamicResource Common_Refresh}" Command="{Binding RefreshCommand}" Padding="12,6" Margin="0,0,8,0"
                        Background="#F0F0F5" BorderThickness="0" Cursor="Hand"/>
                <Button Content="{DynamicResource Log_OpenDirectory}" Command="{Binding OpenLogFolderCommand}" Padding="12,6" Margin="0,0,8,0"/>
                <Button Content="{DynamicResource Log_Clear}" Command="{Binding ClearCommand}" Padding="12,6" Foreground="Red"/>
            </StackPanel>
        </Grid>

        <!-- 日志列表 -->
        <Border Grid.Row="2" Background="#1E1E1E" CornerRadius="4" Padding="8">
            <ListBox ItemsSource="{Binding Logs}" BorderThickness="0" Background="Transparent"
                     Foreground="#D4D4D4" FontFamily="Consolas" FontSize="12"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding DisplayText}" TextWrapping="Wrap" Margin="0,1">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#D4D4D4"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Level}" Value="ERROR">
                                            <Setter Property="Foreground" Value="#F44747"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Level}" Value="WARN">
                                            <Setter Property="Foreground" Value="#FFCC00"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Level}" Value="INFO">
                                            <Setter Property="Foreground" Value="#6A9955"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Level}" Value="DEBUG">
                                            <Setter Property="Foreground" Value="#808080"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- 日志管理设置 -->
        <Border Grid.Row="3" Background="#F8F8F8" CornerRadius="4" Padding="12,8" Margin="0,8,0,0"
                BorderBrush="#E0E0E0" BorderThickness="1">
            <WrapPanel Orientation="Horizontal">
                <TextBlock Text="{DynamicResource Log_Management}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <CheckBox Content="{DynamicResource Log_AutoClean}" IsChecked="{Binding AutoCleanLogs}"
                          VerticalAlignment="Center" Margin="0,0,16,0"/>
                <TextBlock Text="{DynamicResource Log_KeepDays}" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox Text="{Binding LogKeepDays}" Width="50" Padding="4,2" VerticalAlignment="Center"
                         VerticalContentAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Text="{DynamicResource Log_Days}" FontSize="13" VerticalAlignment="Center" Margin="0,0,16,0"/>
                <Button Content="{DynamicResource Log_SaveSettings}" Command="{Binding SaveLogSettingsCommand}"
                        Padding="12,4" Background="#1976D2" Foreground="White" BorderThickness="0"/>
            </WrapPanel>
        </Border>
    </Grid>
</UserControl>
