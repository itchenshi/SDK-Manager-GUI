<UserControl x:Class="SDK_Manager_GUI.Views.SdkDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignHeight="700" d:DesignWidth="900">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Language}" FontSize="24" FontWeight="Bold" Foreground="#1A1A2E" VerticalAlignment="Center"/>
                <TextBlock Text="{DynamicResource Sdk_Manage}" FontSize="24" FontWeight="Bold" Foreground="#1A1A2E" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- 当前版本信息：用户级 + 系统级 -->
        <Border Grid.Row="1" Background="#FFFFFF" CornerRadius="6" Padding="16" Margin="0,0,0,12"
                BorderBrush="#E0E0E0" BorderThickness="1">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 用户级信息 -->
                    <Border Grid.Column="0" Background="#E8F5E9" CornerRadius="4" Padding="12,8" Margin="0,0,6,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#2E7D32">
                                    <Run Text="{DynamicResource Common_UserLevel}"/>
                                </TextBlock>
                                <Button Grid.Column="1" Content="{DynamicResource Common_Uninstall}" Padding="8,2" FontSize="11"
                                        Background="#FFF3E0" Foreground="#E65100" BorderThickness="0" Cursor="Hand"
                                        Command="{Binding UninstallUserLevelCommand}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasUserLevel}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                    <Setter Property="IsEnabled" Value="False"/>
                                                    <Setter Property="Opacity" Value="0.5"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                            <TextBlock Grid.Row="1" FontSize="12" Foreground="#333333" Margin="0,4,0,0">
                                <Run Text="{DynamicResource Common_VersionColon}"/><Run Text="{Binding UserLevelVersionDisplay, Mode=OneWay}" FontWeight="Medium"/>
                            </TextBlock>
                            <!-- SDK 路径 + 复制/打开按钮 -->
                            <Grid Grid.Row="2" Margin="0,2,0,0">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding UserLevelPath}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding UserLevelPath}" FontSize="11" Foreground="#666666"
                                           TextTrimming="CharacterEllipsis" ToolTip="{Binding UserLevelPath}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="4,0,0,0">
                                    <Button Content="{DynamicResource Common_Copy}" Padding="4,1" FontSize="10" Margin="1,0"
                                            Background="#F5F5F5" Foreground="#666666" BorderThickness="0" Cursor="Hand"
                                            Command="{Binding CopyPathCommand}" CommandParameter="{Binding UserLevelPath}"/>
                                    <Button Content="{DynamicResource Common_Open}" Padding="4,1" FontSize="10" Margin="1,0"
                                            Background="#F5F5F5" Foreground="#666666" BorderThickness="0" Cursor="Hand"
                                            Command="{Binding OpenPathCommand}" CommandParameter="{Binding UserLevelPath}"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- 系统级信息 -->
                    <Border Grid.Column="1" Background="#E3F2FD" CornerRadius="4" Padding="12,8" Margin="6,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#1565C0">
                                    <Run Text="{DynamicResource Common_SystemLevel}"/>
                                </TextBlock>
                                <Button Grid.Column="1" Content="{DynamicResource Common_Uninstall}" Padding="8,2" FontSize="11"
                                        Background="#FFEBEE" Foreground="#C62828" BorderThickness="0" Cursor="Hand"
                                        Command="{Binding UninstallSystemLevelCommand}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasSystemLevel}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                    <Setter Property="IsEnabled" Value="False"/>
                                                    <Setter Property="Opacity" Value="0.5"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsRunningAsAdmin}" Value="False">
                                                    <Setter Property="IsEnabled" Value="False"/>
                                                    <Setter Property="Opacity" Value="0.4"/>
                                                    <Setter Property="ToolTip" Value="{DynamicResource Common_RequireAdmin}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                            <TextBlock Grid.Row="1" FontSize="12" Foreground="#333333" Margin="0,4,0,0">
                                <Run Text="{DynamicResource Common_VersionColon}"/><Run Text="{Binding SystemLevelVersionDisplay, Mode=OneWay}" FontWeight="Medium"/>
                            </TextBlock>
                            <!-- SDK 路径 + 复制/打开按钮 -->
                            <Grid Grid.Row="2" Margin="0,2,0,0">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SystemLevelPath}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding SystemLevelPath}" FontSize="11" Foreground="#666666"
                                           TextTrimming="CharacterEllipsis" ToolTip="{Binding SystemLevelPath}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="4,0,0,0">
                                    <Button Content="{DynamicResource Common_Copy}" Padding="4,1" FontSize="10" Margin="1,0"
                                            Background="#F5F5F5" Foreground="#666666" BorderThickness="0" Cursor="Hand"
                                            Command="{Binding CopyPathCommand}" CommandParameter="{Binding SystemLevelPath}"/>
                                    <Button Content="{DynamicResource Common_Open}" Padding="4,1" FontSize="10" Margin="1,0"
                                            Background="#F5F5F5" Foreground="#666666" BorderThickness="0" Cursor="Hand"
                                            Command="{Binding OpenPathCommand}" CommandParameter="{Binding SystemLevelPath}"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>

        <!-- TabControl 主内容区 -->
        <TabControl Grid.Row="2" BorderBrush="#E0E0E0" BorderThickness="1" Padding="0"
                    Background="#FFFFFF">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Padding" Value="20,8"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="FontWeight" Value="Medium"/>
                    <Setter Property="BorderBrush" Value="#E0E0E0"/>
                    <Setter Property="Background" Value="#F5F5F5"/>
                </Style>
            </TabControl.Resources>

            <!-- Tab 1: 版本管理 -->
            <TabItem Header="{DynamicResource Sdk_VersionManagement}">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 筛选栏 -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Width="200" Padding="6,4" Margin="0,0,8,0"
                                 ToolTip="{DynamicResource Sdk_SearchVersion}"/>
                        <ComboBox Width="120" Margin="0,0,8,0"
                                  ItemsSource="{Binding CategoryOptions}"
                                  SelectedItem="{Binding CategoryFilter}"/>
                        <Button Content="{DynamicResource Sdk_RefreshList}" Command="{Binding LoadVersionsCommand}" Padding="12,6" Margin="0,0,8,0"
                                Background="#F0F0F5" BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>

                    <!-- 版本列表 -->
                    <Grid Grid.Row="1">
                        <DataGrid ItemsSource="{Binding Versions}" AutoGenerateColumns="False"
                                  SelectedItem="{Binding SelectedVersion}" IsReadOnly="True"
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  BorderBrush="#E0E0E0" BorderThickness="1"
                                  GridLinesVisibility="Horizontal" HeadersVisibility="Column">
                            <DataGrid.Style>
                                <Style TargetType="DataGrid">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.Style>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{DynamicResource Common_Version}" Binding="{Binding Version}" Width="150"/>
                                <DataGridTextColumn Header="{DynamicResource Common_Category}" Binding="{Binding CategoryDisplay}" Width="80"/>
                                <DataGridTextColumn Header="{DynamicResource Common_Status}" Binding="{Binding StatusText}" Width="120">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#666666"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                    <Setter Property="Foreground" Value="#4CAF50"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn x:Name="ReleaseDateColumn" Header="{DynamicResource Common_ReleaseDate}" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ReleaseDate, StringFormat=yyyy-MM-dd}" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="{DynamicResource Common_Action}" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="{DynamicResource Common_UserLevelInstall}" Padding="8,2" Margin="2"
                                                        Background="#E8F5E9" Foreground="#2E7D32" BorderThickness="0"
                                                        Command="{Binding DataContext.InstallCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Setter Property="IsEnabled" Value="True"/>
                                                            <Style.Triggers>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding IsUserLevelInstalled}" Value="False"/>
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </MultiDataTrigger>
                                                                <DataTrigger Binding="{Binding DataContext.IsBusy, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="True">
                                                                    <Setter Property="IsEnabled" Value="False"/>
                                                                    <Setter Property="Opacity" Value="0.5"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                                <Button Content="{DynamicResource Common_UserLevelUninstall}" Padding="8,2" Margin="2"
                                                        Background="#FFF3E0" Foreground="#E65100" BorderThickness="0"
                                                        Command="{Binding DataContext.UninstallUserCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Setter Property="IsEnabled" Value="True"/>
                                                            <Style.Triggers>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding IsUserLevelInstalled}" Value="True"/>
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </MultiDataTrigger>
                                                                <DataTrigger Binding="{Binding DataContext.IsBusy, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="True">
                                                                    <Setter Property="IsEnabled" Value="False"/>
                                                                    <Setter Property="Opacity" Value="0.5"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                                <Button Content="{DynamicResource Common_SystemLevelInstall}" Padding="8,2" Margin="2"
                                                        Background="#E3F2FD" Foreground="#1565C0" BorderThickness="0"
                                                        Command="{Binding DataContext.InstallSystemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Setter Property="IsEnabled" Value="True"/>
                                                            <Style.Triggers>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding IsSystemLevelInstalled}" Value="False"/>
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </MultiDataTrigger>
                                                                <DataTrigger Binding="{Binding DataContext.IsBusy, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="True">
                                                                    <Setter Property="IsEnabled" Value="False"/>
                                                                    <Setter Property="Opacity" Value="0.5"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding DataContext.IsRunningAsAdmin, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="False">
                                                                    <Setter Property="IsEnabled" Value="False"/>
                                                                    <Setter Property="Opacity" Value="0.4"/>
                                                                    <Setter Property="ToolTip" Value="{DynamicResource Common_RequireAdmin}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                                <Button Content="{DynamicResource Common_SystemLevelUninstall}" Padding="8,2" Margin="2"
                                                        Background="#FFEBEE" Foreground="#C62828" BorderThickness="0"
                                                        Command="{Binding DataContext.UninstallSystemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Setter Property="IsEnabled" Value="True"/>
                                                            <Style.Triggers>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding IsSystemLevelInstalled}" Value="True"/>
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </MultiDataTrigger>
                                                                <DataTrigger Binding="{Binding DataContext.IsBusy, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="True">
                                                                    <Setter Property="IsEnabled" Value="False"/>
                                                                    <Setter Property="Opacity" Value="0.5"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding DataContext.IsRunningAsAdmin, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="False">
                                                                    <Setter Property="IsEnabled" Value="False"/>
                                                                    <Setter Property="Opacity" Value="0.4"/>
                                                                    <Setter Property="ToolTip" Value="{DynamicResource Common_RequireAdmin}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- 卸载遮罩层 -->
                        <Border Background="#80000000" CornerRadius="4"
                                Visibility="{Binding IsUninstalling, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="{Binding ProgressMessage}" FontSize="14" Foreground="#FFFFFF"
                                           HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                <ProgressBar IsIndeterminate="True" Height="8" Width="200"
                                             Foreground="#FF6B6B" Background="#40FFFFFF"/>
                                <TextBlock Text="{DynamicResource Common_PleaseWait}" FontSize="11" Foreground="#CCCCCC"
                                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- 加载中提示 -->
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="{DynamicResource Sdk_LoadingVersions}" FontSize="14" Foreground="#999999" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- 空列表提示 -->
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsLoading}" Value="False"/>
                                                <Condition Binding="{Binding Versions.Count}" Value="0"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="{DynamicResource Sdk_NoVersions}" FontSize="14" Foreground="#999999" HorizontalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Sdk_CheckNetworkRefresh}" FontSize="12" Foreground="#BBBBBB"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Tab 2: 下载镜像源 -->
            <TabItem Header="{DynamicResource Sdk_DownloadMirror}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                    <StackPanel>
                        <!-- 说明 -->
                        <Border Background="#F0F4FF" CornerRadius="4" Padding="12,8" Margin="0,0,0,12"
                                BorderBrush="#C5CAE9" BorderThickness="1">
                            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#37474F" LineHeight="20">
                                <Run FontWeight="Bold" Text="{DynamicResource Sdk_DownloadMirror}"/><Run Text="{DynamicResource Sdk_DownloadMirrorDesc}"/>
                            </TextBlock>
                        </Border>

                        <!-- 添加/编辑镜像 -->
                        <Border Background="#FFFFFF" CornerRadius="6" Padding="16" Margin="0,0,0,12"
                                BorderBrush="#E0E0E0" BorderThickness="1">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="#333333">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{DynamicResource Common_AddCustomMirror}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEditingMirror}" Value="True">
                                                        <Setter Property="Text" Value="{DynamicResource Common_EditMirror}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <Button Grid.Column="1" Content="{DynamicResource Common_CancelEdit}" Padding="8,2" FontSize="11"
                                            Background="#F5F5F5" BorderThickness="0" Cursor="Hand"
                                            Command="{Binding CancelEditMirrorCommand}">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEditingMirror}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource Common_Name}" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12"/>
                                    <TextBox Grid.Column="1" Text="{Binding NewMirrorName, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="6,4" FontSize="12" Margin="0,0,10,0"/>
                                    <TextBlock Grid.Column="2" Text="URL:" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12"/>
                                    <TextBox Grid.Column="3" Text="{Binding NewMirrorUrl, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="6,4" FontSize="12" Margin="0,0,10,0"/>
                                    <Button Grid.Column="4" Content="{Binding MirrorSaveButtonText}" Command="{Binding SaveMirrorCommand}"
                                            Padding="14,6" FontSize="12" Background="#0066CC" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- 镜像列表 -->
                        <Border Background="#FFFFFF" CornerRadius="6" Padding="16"
                                BorderBrush="#E0E0E0" BorderThickness="1">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource Common_MirrorList}" FontSize="14" FontWeight="SemiBold" Foreground="#333333"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Content="{DynamicResource Common_TestAllLatency}" Command="{Binding TestMirrorLatencyCommand}" Padding="8,4" FontSize="11"
                                                Background="#F0F0F5" BorderThickness="0" Cursor="Hand" Margin="0,0,6,0"/>
                                        <Button Content="{DynamicResource Common_Refresh}" Command="{Binding LoadMirrorsCommand}"
                                                Padding="8,4" FontSize="11" Background="#F0F0F5" BorderThickness="0" Cursor="Hand"/>
                                    </StackPanel>
                                </Grid>
                                <DataGrid ItemsSource="{Binding Mirrors}" AutoGenerateColumns="False"
                                          SelectedItem="{Binding SelectedMirror}" IsReadOnly="True"
                                          CanUserAddRows="False" BorderBrush="#E0E0E0" BorderThickness="1"
                                          GridLinesVisibility="Horizontal" MaxHeight="300" FontSize="12">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="{DynamicResource Common_Name}" Binding="{Binding Name}" Width="130"/>
                                        <DataGridTextColumn Header="URL" Binding="{Binding BaseUrl}" Width="*"/>
                                        <DataGridCheckBoxColumn Header="{DynamicResource Common_Enabled}" Binding="{Binding IsEnabled}" Width="50"/>
                                        <DataGridTextColumn Header="{DynamicResource Common_Latency}" Width="70">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                            <DataGridTextColumn.Binding>
                                                <Binding Path="Latency" Converter="{StaticResource NullableLongToStringConverter}"/>
                                            </DataGridTextColumn.Binding>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="{DynamicResource Common_Status}" Width="65">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                            <DataGridTextColumn.Binding>
                                                <Binding Path="LastSuccess" Converter="{StaticResource NullableBoolToStatusConverter}"/>
                                            </DataGridTextColumn.Binding>
                                        </DataGridTextColumn>
                                        <DataGridTemplateColumn Header="{DynamicResource Common_Action}" Width="180">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Button Padding="6,2" FontSize="10" Margin="1"
                                                                Command="{Binding DataContext.ToggleMirrorCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                CommandParameter="{Binding}">
                                                            <Button.Style>
                                                                <Style TargetType="Button">
                                                                    <Setter Property="Content" Value="{DynamicResource Common_Disable}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                                            <Setter Property="Content" Value="{DynamicResource Common_Enable}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>
                                                        <Button Content="{DynamicResource Common_Edit}" Padding="6,2" FontSize="10" Margin="1"
                                                                Command="{Binding DataContext.EditMirrorCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                CommandParameter="{Binding}"/>
                                                        <Button Content="{DynamicResource Common_Delete}" Padding="6,2" FontSize="10" Margin="1" Foreground="Red"
                                                                Command="{Binding DataContext.RemoveMirrorCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                CommandParameter="{Binding}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>


            <!-- Tab 4: 包管理器镜像源（Python=pip, NodeJs=npm） -->
            <TabItem Header="{Binding PackageManagerMirrorTabTitle}">
                <TabItem.Style>
                    <Style TargetType="TabItem">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SupportsPackageManagerMirror}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TabItem.Style>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                    <StackPanel>
                        <!-- 说明 -->
                        <Border Background="#F0F4FF" CornerRadius="4" Padding="12,8" Margin="0,0,0,12"
                                BorderBrush="#C5CAE9" BorderThickness="1">
                            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#37474F" LineHeight="20">
                                <Run Text="{Binding PackageManagerMirrorDescription, Mode=OneWay}"/>
                            </TextBlock>
                        </Border>

                        <!-- 当前配置 -->
                        <Border Background="#FFFFFF" CornerRadius="6" Padding="16" Margin="0,0,0,12"
                                BorderBrush="#E0E0E0" BorderThickness="1">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding PackageManagerMirrorSectionTitle}" FontSize="14" FontWeight="SemiBold" Foreground="#333333"/>
                                    <Button Grid.Column="1" Content="{DynamicResource Common_DetectCurrentConfig}" Command="{Binding DetectPackageManagerMirrorCommand}"
                                            Padding="10,4" FontSize="11" Background="#F0F0F5" BorderThickness="0" Cursor="Hand"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource Common_CurrentMirror}" FontSize="12" VerticalAlignment="Center" Foreground="#666666"/>
                                    <TextBlock Grid.Column="1" Text="{Binding CurrentPackageManagerMirror}" FontSize="12"
                                               Foreground="#333333" TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding CurrentPackageManagerMirror}" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- 快速设置 -->
                        <Border Background="#FFFFFF" CornerRadius="6" Padding="16" Margin="0,0,0,12"
                                BorderBrush="#E0E0E0" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Common_QuickSetup}" FontSize="14" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,8"/>
                                <ItemsControl ItemsSource="{Binding PresetPackageManagerMirrors}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding Name}" Padding="12,6" Margin="0,0,8,8"
                                                    FontSize="12" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="1"
                                                    Cursor="Hand"
                                                    Command="{Binding DataContext.SetPackageManagerMirrorCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- 自定义URL -->
                        <Border Background="#FFFFFF" CornerRadius="6" Padding="16"
                                BorderBrush="#E0E0E0" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Common_CustomMirror}" FontSize="14" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding CustomPackageManagerMirrorUrl, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="6,4" FontSize="12" Margin="0,0,10,0"
                                             ToolTip="{DynamicResource Common_InputMirrorURL}"/>
                                    <Button Grid.Column="1" Content="{DynamicResource Common_Apply}" Command="{Binding ApplyCustomPackageManagerMirrorCommand}"
                                            Padding="14,6" FontSize="12" Background="#0066CC" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 4: 说明 -->
            <TabItem Header="{DynamicResource Sdk_Description}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                    <StackPanel>
                        <!-- 安装操作步骤 -->
                        <Border Background="#FFFFFF" CornerRadius="6" Padding="16" Margin="0,0,0,12"
                                BorderBrush="#E0E0E0" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Sdk_InstallSteps}" FontSize="16" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,10"/>
                                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#444444" LineHeight="22"
                                           Text="{Binding InstallStepsText, Converter={StaticResource NewlineConverter}}"/>
                            </StackPanel>
                        </Border>

                        <!-- 安装执行命令 -->
                        <Border Background="#F5F5F5" CornerRadius="6" Padding="16" Margin="0,0,0,12"
                                BorderBrush="#E0E0E0" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Sdk_InstallCommands}" FontSize="16" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,10"/>
                                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#444444" LineHeight="22"
                                           Text="{Binding InstallCommandsText, Converter={StaticResource NewlineConverter}}"/>
                            </StackPanel>
                        </Border>

                        <!-- 卸载操作步骤 -->
                        <Border Background="#FFFFFF" CornerRadius="6" Padding="16" Margin="0,0,0,12"
                                BorderBrush="#E0E0E0" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Sdk_UninstallSteps}" FontSize="16" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,10"/>
                                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#444444" LineHeight="22"
                                           Text="{Binding UninstallStepsText, Converter={StaticResource NewlineConverter}}"/>
                            </StackPanel>
                        </Border>

                        <!-- 卸载执行命令 -->
                        <Border Background="#F5F5F5" CornerRadius="6" Padding="16" Margin="0,0,0,12"
                                BorderBrush="#E0E0E0" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Sdk_UninstallCommands}" FontSize="16" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,10"/>
                                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#444444" LineHeight="22"
                                           Text="{Binding UninstallCommandsText, Converter={StaticResource NewlineConverter}}"/>
                            </StackPanel>
                        </Border>

                        <!-- 镜像源设置说明（Python、NodeJs、Java 显示） -->
                        <Border Background="#E3F2FD" CornerRadius="6" Padding="16"
                                BorderBrush="#90CAF9" BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Language}" Value="NodeJs">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Language}" Value="Python">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="{Binding MirrorSetupTitle}" FontSize="16" FontWeight="SemiBold" Foreground="#1565C0" Margin="0,0,0,10"/>
                                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#333333" LineHeight="22"
                                           Text="{Binding MirrorSetupText, Converter={StaticResource NewlineConverter}}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- 操作进度 -->
        <Grid Grid.Row="3" Margin="0,8,0,0">
            <!-- 安装进度 -->
            <StackPanel Visibility="{Binding IsInstalling, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="{Binding ProgressMessage}" FontSize="12" Foreground="#666666" Margin="0,0,0,4"/>
                <ProgressBar Value="{Binding OperationProgress}" Maximum="100" Height="6"/>
            </StackPanel>

            <!-- 卸载进度提示 -->
            <StackPanel Visibility="{Binding IsUninstalling, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="{Binding ProgressMessage}" FontSize="12" Foreground="#E65100" Margin="0,0,0,4"/>
                <ProgressBar IsIndeterminate="True" Height="6" Foreground="#FF6B6B"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
