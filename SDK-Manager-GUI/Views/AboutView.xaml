<UserControl x:Class="SDK_Manager_GUI.Views.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignHeight="600" d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,16">
            <!-- 页面标题 - 与其他页面一致 -->
            <TextBlock Text="{DynamicResource About_Title}" FontSize="24" FontWeight="Bold" Foreground="#1A1A2E" Margin="0,0,0,16"/>

            <!-- 应用信息卡片 -->
            <Border Background="#FFFFFF" CornerRadius="6" Padding="16" Margin="0,0,0,12"
                    BorderBrush="#E0E0E0" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左列：应用基本信息 -->
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="{Binding AppName}" FontSize="22" FontWeight="Bold" Foreground="#1A1A2E" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="{DynamicResource About_Version}" FontSize="13" Foreground="#888888" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Version}" FontSize="13" Foreground="#0066CC" FontWeight="Medium" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding Description}" FontSize="12" Foreground="#666666" Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding Copyright}" FontSize="12" Foreground="#999999"/>
                    </StackPanel>

                    <!-- 右列：技术信息 -->
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{DynamicResource About_TechStack}" FontSize="14" FontWeight="SemiBold" Foreground="#1A1A2E" Margin="0,0,0,8"/>
                        <TextBlock Text=".NET Framework 4.8 / WPF" FontSize="12" Foreground="#666666" Margin="0,0,0,4"/>
                        <TextBlock Text="{DynamicResource About_MvvmArch}" FontSize="12" Foreground="#666666" Margin="0,0,0,4"/>
                        <TextBlock Text="MIT License" FontSize="12" Foreground="#666666" Margin="0,0,0,8"/>
                        <TextBlock Text="{DynamicResource About_Dependencies}" FontSize="14" FontWeight="SemiBold" Foreground="#1A1A2E" Margin="0,0,0,6"/>
                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#888888">
                            Newtonsoft.Json · Dapper · System.Data.SQLite · Serilog
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 功能特性卡片 -->
            <Border Background="#FFFFFF" CornerRadius="6" Padding="16" Margin="0,0,0,12"
                    BorderBrush="#E0E0E0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="{DynamicResource About_Features}" FontSize="16" FontWeight="SemiBold" Foreground="#1A1A2E" Margin="0,0,0,12"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 左列 -->
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <!-- SDK 管理 -->
                            <Border Background="#E8F5E9" CornerRadius="4" Padding="10,8" Margin="0,0,0,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource About_Feature_SdkManage}" FontSize="13" FontWeight="SemiBold" Foreground="#2E7D32"
                                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Grid.Column="1" Text="{DynamicResource About_Feature_SdkManageDesc}"
                                               FontSize="11" Foreground="#666666" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                </Grid>
                            </Border>

                            <!-- Maven 管理 -->
                            <Border Background="#E3F2FD" CornerRadius="4" Padding="10,8" Margin="0,0,0,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource About_Feature_MavenManage}" FontSize="13" FontWeight="SemiBold" Foreground="#1565C0"
                                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Grid.Column="1" Text="{DynamicResource About_Feature_MavenManageDesc}"
                                               FontSize="11" Foreground="#666666" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                </Grid>
                            </Border>

                            <!-- 镜像源 -->
                            <Border Background="#FFF8E1" CornerRadius="4" Padding="10,8" Margin="0,0,0,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource About_Feature_Mirror}" FontSize="13" FontWeight="SemiBold" Foreground="#E65100"
                                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Grid.Column="1" Text="{DynamicResource About_Feature_MirrorDesc}"
                                               FontSize="11" Foreground="#666666" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                </Grid>
                            </Border>

                            <!-- 环境变量 -->
                            <Border Background="#F3E5F5" CornerRadius="4" Padding="10,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource About_Feature_EnvVar}" FontSize="13" FontWeight="SemiBold" Foreground="#7B1FA2"
                                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Grid.Column="1" Text="{DynamicResource About_Feature_EnvVarDesc}"
                                               FontSize="11" Foreground="#666666" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- 右列 -->
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <!-- 版本切换 -->
                            <Border Background="#E0F2F1" CornerRadius="4" Padding="10,8" Margin="0,0,0,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource About_Feature_VersionSwitch}" FontSize="13" FontWeight="SemiBold" Foreground="#00695C"
                                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Grid.Column="1" Text="{DynamicResource About_Feature_VersionSwitchDesc}"
                                               FontSize="11" Foreground="#666666" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                </Grid>
                            </Border>

                            <!-- 下载管理 -->
                            <Border Background="#E8EAF6" CornerRadius="4" Padding="10,8" Margin="0,0,0,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource About_Feature_Download}" FontSize="13" FontWeight="SemiBold" Foreground="#283593"
                                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Grid.Column="1" Text="{DynamicResource About_Feature_DownloadDesc}"
                                               FontSize="11" Foreground="#666666" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                </Grid>
                            </Border>

                            <!-- 仪表盘 -->
                            <Border Background="#FCE4EC" CornerRadius="4" Padding="10,8" Margin="0,0,0,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource About_Feature_Dashboard}" FontSize="13" FontWeight="SemiBold" Foreground="#C62828"
                                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Grid.Column="1" Text="{DynamicResource About_Feature_DashboardDesc}"
                                               FontSize="11" Foreground="#666666" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                </Grid>
                            </Border>

                            <!-- 日志管理 -->
                            <Border Background="#ECEFF1" CornerRadius="4" Padding="10,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource About_Feature_Log}" FontSize="13" FontWeight="SemiBold" Foreground="#546E7A"
                                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Grid.Column="1" Text="{DynamicResource About_Feature_LogDesc}"
                                               FontSize="11" Foreground="#666666" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
