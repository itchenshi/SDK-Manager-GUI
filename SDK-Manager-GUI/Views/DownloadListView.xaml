<UserControl x:Class="SDK_Manager_GUI.Views.DownloadListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignHeight="600" d:DesignWidth="800">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,0,0,16">
            <!-- 标题栏 -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{DynamicResource Download_Title}" FontSize="24" FontWeight="Bold" Foreground="#1A1A2E"/>
                    <TextBlock FontSize="12" Foreground="#888888" Margin="0,4,0,0">
                        <Run Text="{Binding TaskSummary, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <ComboBox ItemsSource="{Binding StatusFilterOptions}" SelectedItem="{Binding StatusFilter}"
                              Margin="0,0,12,0" Padding="8,4" FontSize="12" Width="90"/>
                    <Button Content="{DynamicResource Common_OpenDirectory}" Command="{Binding OpenDefaultDirectoryCommand}"
                            Padding="12,6" FontSize="12" Background="#E3F2FD" Foreground="#1565C0" BorderThickness="0" Cursor="Hand"
                            Margin="0,0,8,0"/>
                    <Button Content="{DynamicResource Download_ClearCompleted}" Command="{Binding ClearCompletedCommand}"
                            Padding="12,6" FontSize="12" Background="#FFEBEE" Foreground="#C62828" BorderThickness="0" Cursor="Hand"
                            Margin="0,0,8,0"/>
                    <Button Content="{DynamicResource Common_Refresh}" Command="{Binding RefreshCommand}"
                            Padding="16,8" FontSize="13" Background="#F0F0F5" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </Grid>

            <!-- 空状态 -->
            <Border Background="#FAFAFA" CornerRadius="8" Padding="40,32">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasAnyTasks}" Value="False">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{DynamicResource Download_NoTasks}" FontSize="14" Foreground="#AAAAAA" HorizontalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource Download_AutoShowProgress}" FontSize="12" Foreground="#CCCCCC"
                               HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <!-- 统一任务列表 -->
            <ItemsControl ItemsSource="{Binding AllTasks}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#FFFFFF" CornerRadius="8" Margin="0,0,0,8"
                                BorderBrush="#E8E8F0" BorderThickness="1" Padding="14,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- 第一行：SDK名称、版本、状态、操作 -->
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 状态指示点 -->
                                    <Ellipse Grid.Column="0" Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="#2196F3"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                        <Setter Property="Fill" Value="#4CAF50"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                        <Setter Property="Fill" Value="#E53935"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Cancelled">
                                                        <Setter Property="Fill" Value="#9E9E9E"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Paused">
                                                        <Setter Property="Fill" Value="#FF9800"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                        <Setter Property="Fill" Value="#BDBDBD"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>

                                    <!-- SDK名称标签 -->
                                    <Border Grid.Column="1" Background="#E8F5E9" CornerRadius="3" Padding="5,2" Margin="0,0,8,0">
                                        <TextBlock Text="{Binding SdkName}" FontSize="11" FontWeight="Medium" Foreground="#2E7D32"/>
                                    </Border>

                                    <!-- 版本 -->
                                    <TextBlock Grid.Column="2" Text="{Binding Version}" FontSize="13" FontWeight="SemiBold"
                                               Foreground="#333333" VerticalAlignment="Center" Margin="0,0,12,0"/>

                                    <!-- 状态文字（仅非下载中显示） -->
                                    <TextBlock Grid.Column="3" FontSize="11" VerticalAlignment="Center" TextTrimming="CharacterEllipsis">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Setter Property="Foreground" Value="#888888"/>
                                                <Setter Property="Text" Value="{Binding MirrorName}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Downloading">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                        <Setter Property="Text" Value="{Binding ErrorMessage}"/>
                                                        <Setter Property="Foreground" Value="#E53935"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                        <Setter Property="Text" Value="{Binding CompletedInfo}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!-- 操作按钮 -->
                                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                                        <!-- 暂停 -->
                                        <Button Content="{DynamicResource Download_Pause}" Padding="8,3" FontSize="11" Margin="2,0"
                                                Background="#FFF3E0" Foreground="#E65100" BorderThickness="0" Cursor="Hand"
                                                Command="{Binding DataContext.PauseDownloadCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding TaskId}">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding Status}" Value="Downloading"/>
                                                                <Condition Binding="{Binding CanPause}" Value="True"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <!-- 继续 -->
                                        <Button Content="{DynamicResource Download_Resume}" Padding="8,3" FontSize="11" Margin="2,0"
                                                Background="#E8F5E9" Foreground="#2E7D32" BorderThickness="0" Cursor="Hand"
                                                Command="{Binding DataContext.ResumeDownloadCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding TaskId}">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Paused">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <!-- 取消 -->
                                        <Button Content="{DynamicResource Download_Cancel}" Padding="8,3" FontSize="11" Margin="2,0"
                                                Background="#FFEBEE" Foreground="#C62828" BorderThickness="0" Cursor="Hand"
                                                Command="{Binding DataContext.CancelDownloadCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding TaskId}">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Downloading">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Paused">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <!-- 重试 -->
                                        <Button Content="{DynamicResource Download_Retry}" Padding="8,3" FontSize="11" Margin="2,0"
                                                Background="#E8F5E9" Foreground="#2E7D32" BorderThickness="0" Cursor="Hand"
                                                Command="{Binding DataContext.RetryDownloadCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding TaskId}">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Cancelled">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <!-- 删除 -->
                                        <Button Content="{DynamicResource Common_Delete}" Padding="8,3" FontSize="11" Margin="2,0"
                                                Background="#FFEBEE" Foreground="#C62828" BorderThickness="0" Cursor="Hand"
                                                Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Cancelled">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </Grid>

                                <!-- 第二行：进度条（仅下载中显示） -->
                                <Grid Grid.Row="1" Margin="0,8,0,0">
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="Downloading">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Paused">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <ProgressBar Value="{Binding Progress}" Maximum="100" Height="5"
                                                 Foreground="#4CAF50" Background="#F0F0F0" Margin="0,0,0,4"/>

                                    <Grid Grid.Row="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{Binding ProgressDisplay}" FontSize="11" Foreground="#666666"/>
                                        <TextBlock Grid.Column="1" Text="{Binding SpeedDisplay}" FontSize="11" Foreground="#0066CC"
                                                   Margin="12,0,0,0" FontWeight="Medium"/>
                                        <TextBlock Grid.Column="2" Text="{Binding MirrorName}" FontSize="11" Foreground="#AAAAAA"
                                                   Margin="12,0,0,0"/>
                                        <TextBlock Grid.Column="3" Text="{Binding RemainingTimeDisplay}" FontSize="11" Foreground="#888888"/>
                                    </Grid>
                                </Grid>

                                <!-- 第三行：保存目录 + 打开目录按钮（仅下载中/暂停时显示） -->
                                <Grid Grid.Row="2" Margin="0,6,0,0">
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="Downloading">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Paused">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="{DynamicResource Download_SaveDirectory}" FontSize="11" Foreground="#888888"
                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SaveDirectory}" FontSize="11" Foreground="#666666"
                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                    <Button Grid.Column="2" Content="{DynamicResource Common_OpenDirectory}" Padding="6,2" FontSize="11" Margin="8,0,0,0"
                                            Background="#E3F2FD" Foreground="#1565C0" BorderThickness="0" Cursor="Hand"
                                            Command="{Binding DataContext.OpenDirectoryCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
